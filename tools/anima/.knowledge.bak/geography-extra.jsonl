// geography — "sai cos'è X?" general-knowledge cards (7b drafts, rewritten/verified). Bilingual IT/EN.
{"id": "geo.equator", "category": "geography", "action": "answer", "arg": "", "reply": {"it": "L'equatore è la linea immaginaria che gira attorno alla Terra a 0 gradi di latitudine, dividendola negli emisferi nord e sud.", "en": "The equator is the imaginary line that circles the Earth at 0 degrees latitude, dividing it into the northern and southern hemispheres."}, "ask": {"it": ["cos'è l'equatore", "che cos'è l'equatore", "dove si trova l'equatore", "cosa divide la terra in due emisferi"], "en": ["what is the equator", "where is the equator", "what divides the earth into two hemispheres"]}, "detail": {"it": "Lungo l'equatore il clima è caldo e le ore di luce restano quasi costanti tutto l'anno. Paesi come l'Ecuador lo attraversano.", "en": "Along the equator the climate is hot and daylight hours stay nearly constant all year. Countries such as Ecuador lie on it."}, "source": "llm-draft:7b+reviewed:claude"}
{"id": "geo.poles", "category": "geography", "action": "answer", "arg": "", "reply": {"it": "I poli sono i due punti estremi dell'asse di rotazione terrestre: il Polo Nord e il Polo Sud.", "en": "The poles are the two extreme points of the Earth's axis of rotation: the North Pole and the South Pole."}, "ask": {"it": ["cosa sono i poli", "cosa sono il polo nord e il polo sud", "che cosa sono i poli terrestri", "dove si trovano i poli"], "en": ["what are the poles", "what are the north and south poles", "where are the poles"]}, "detail": {"it": "Il Polo Nord si trova nell'Oceano Artico ghiacciato, il Polo Sud nel continente Antartide. Sono le zone più fredde del pianeta.", "en": "The North Pole lies in the frozen Arctic Ocean, the South Pole on the continent of Antarctica. They are the coldest areas on the planet."}, "source": "llm-draft:7b+reviewed:claude"}
{"id": "geo.timezones", "category": "geography", "action": "answer", "arg": "", "reply": {"it": "I fusi orari sono le fasce in cui è divisa la Terra, ciascuna con la stessa ora ufficiale.", "en": "Time zones are the bands into which the Earth is divided, each keeping the same official time."}, "ask": {"it": ["cosa sono i fusi orari", "cos'è un fuso orario", "che cosa sono i fusi orari", "perché c'è differenza di ora tra i paesi"], "en": ["what are time zones", "what is a time zone", "why is there a time difference between countries"]}, "detail": {"it": "Sono circa 24, distanziati di un'ora, a partire dal meridiano di Greenwich (UTC). Andando verso est l'ora aumenta, verso ovest diminuisce.", "en": "There are about 24, spaced one hour apart, starting from the Greenwich meridian (UTC). Going east the time increases, going west it decreases."}, "source": "llm-draft:7b+reviewed:claude"}
{"id": "geo.tectonic-plates", "category": "geography", "action": "answer", "arg": "", "reply": {"it": "Le placche tettoniche sono le grandi porzioni in cui è suddivisa la crosta terrestre, che si muovono lentamente sul mantello.", "en": "Tectonic plates are the large sections into which the Earth's crust is divided, slowly moving over the mantle."}, "ask": {"it": ["cosa sono le placche tettoniche", "che cosa sono le placche tettoniche", "cosa sono le zolle tettoniche", "come si muove la crosta terrestre"], "en": ["what are tectonic plates", "how does the earth's crust move"]}, "detail": {"it": "Si spostano di pochi centimetri all'anno; ai loro bordi si formano terremoti, vulcani e catene montuose.", "en": "They move a few centimeters per year; at their boundaries earthquakes, volcanoes, and mountain ranges form."}, "source": "llm-draft:7b+reviewed:claude"}
{"id": "geo.volcano", "category": "geography", "action": "answer", "arg": "", "reply": {"it": "Un vulcano è un'apertura nella crosta terrestre da cui escono lava, gas e frammenti di roccia dall'interno della Terra.", "en": "A volcano is an opening in the Earth's crust from which lava, gas, and rock fragments erupt from the planet's interior."}, "ask": {"it": ["cos'è un vulcano", "che cos'è un vulcano", "come funziona un vulcano", "cosa esce da un vulcano"], "en": ["what is a volcano", "how does a volcano work", "what comes out of a volcano"]}, "detail": {"it": "Il materiale fuso sotto terra si chiama magma; quando esce in superficie diventa lava. Esempi famosi sono il Vesuvio e l'Etna.", "en": "The molten material underground is called magma; once it reaches the surface it becomes lava. Famous examples are Vesuvius and Etna."}, "source": "llm-draft:7b+reviewed:claude"}
{"id": "geo.earthquake", "category": "geography", "action": "answer", "arg": "", "reply": {"it": "Un terremoto è un'improvvisa scossa del suolo causata dal movimento delle placche tettoniche.", "en": "An earthquake is a sudden shaking of the ground caused by the movement of tectonic plates."}, "ask": {"it": ["cos'è un terremoto", "che cos'è un terremoto", "cosa causa un terremoto", "perché avvengono i terremoti"], "en": ["what is an earthquake", "what causes an earthquake", "why do earthquakes happen"]}, "detail": {"it": "L'energia si libera da un punto detto ipocentro; la forza si misura con la scala Richter usando il sismografo.", "en": "The energy is released from a point called the hypocenter; its strength is measured on the Richter scale using a seismograph."}, "source": "llm-draft:7b+reviewed:claude"}
{"id": "geo.climate-zones", "category": "geography", "action": "answer", "arg": "", "reply": {"it": "Le zone climatiche sono le grandi fasce della Terra con clima simile: tropicale, temperata e polare.", "en": "Climate zones are the broad bands of the Earth with a similar climate: tropical, temperate, and polar."}, "ask": {"it": ["cosa sono le zone climatiche", "quali sono le zone climatiche", "che cosa sono le fasce climatiche", "come si dividono i climi della terra"], "en": ["what are climate zones", "what are the climate zones", "how are the earth's climates divided"]}, "detail": {"it": "Dipendono soprattutto dalla latitudine: vicino all'equatore fa caldo tutto l'anno, ai poli fa freddo, in mezzo il clima è temperato.", "en": "They depend mainly on latitude: near the equator it is hot all year, at the poles it is cold, and in between the climate is temperate."}, "source": "llm-draft:7b+reviewed:claude"}
