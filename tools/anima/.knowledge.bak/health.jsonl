// health — "sai cos'è X?" general-knowledge cards (7b drafts, rewritten/verified). Bilingual IT/EN.
{"id": "health.nutrition", "category": "health", "action": "answer", "arg": "", "reply": {"it": "L'alimentazione sana consiste nel seguire una dieta equilibrata che fornisce tutti i nutrienti di cui il corpo ha bisogno.", "en": "Healthy nutrition means following a balanced diet that provides all the nutrients the body needs."}, "ask": {"it": ["cos'è l'alimentazione sana", "cosa significa mangiare sano", "che cos'è una dieta equilibrata", "come si mangia in modo sano"], "en": ["what is healthy nutrition", "what does eating healthy mean", "what is a balanced diet"]}, "detail": {"it": "Comprende frutta, verdura, cereali, proteine e grassi buoni nelle giuste proporzioni, limitando zuccheri e cibi molto elaborati.", "en": "It includes fruit, vegetables, grains, proteins, and healthy fats in the right proportions, while limiting sugar and highly processed foods."}, "source": "llm-draft:7b+reviewed:claude"}
{"id": "health.vitamins", "category": "health", "action": "answer", "arg": "", "reply": {"it": "Le vitamine sono sostanze essenziali, necessarie in piccole quantità, che il corpo usa per funzionare e restare in salute.", "en": "Vitamins are essential substances, needed in small amounts, that the body uses to function and stay healthy."}, "ask": {"it": ["cosa sono le vitamine", "che cosa sono le vitamine", "a cosa servono le vitamine", "perché servono le vitamine"], "en": ["what are vitamins", "what are vitamins for", "why do we need vitamins"]}, "detail": {"it": "Si assumono soprattutto con il cibo. Per esempio la vitamina C rafforza le difese, la vitamina D aiuta a fissare il calcio nelle ossa.", "en": "They come mainly from food. For example, vitamin C supports the immune defenses, and vitamin D helps fix calcium in the bones."}, "source": "llm-draft:7b+reviewed:claude"}
{"id": "health.exercise", "category": "health", "action": "answer", "arg": "", "reply": {"it": "L'esercizio fisico è qualsiasi attività del corpo che mantiene o migliora la forma fisica e la salute.", "en": "Physical exercise is any bodily activity that maintains or improves physical fitness and health."}, "ask": {"it": ["cos'è l'esercizio fisico", "cos'è l'attività fisica", "che cos'è lo sport", "perché fa bene il movimento"], "en": ["what is physical exercise", "what is physical activity", "why is exercise good for you"]}, "detail": {"it": "Comprende attività come camminare, correre, nuotare e andare in bicicletta. L'attività regolare rafforza cuore, muscoli e umore.", "en": "It includes activities such as walking, running, swimming, and cycling. Regular activity strengthens the heart, muscles, and mood."}, "source": "llm-draft:7b+reviewed:claude"}
{"id": "health.sleep", "category": "health", "action": "answer", "arg": "", "reply": {"it": "Il sonno è lo stato di riposo in cui il corpo recupera le energie e la mente rielabora le esperienze della giornata.", "en": "Sleep is the state of rest in which the body restores energy and the mind processes the day's experiences."}, "ask": {"it": ["cos'è il sonno", "che cos'è il sonno", "a cosa serve dormire", "perché dormiamo"], "en": ["why do we sleep", "what is sleep for", "what happens when we sleep"]}, "detail": {"it": "Durante il sonno il corpo ripara i tessuti e consolida la memoria. Un adulto ha bisogno in media di 7-9 ore a notte.", "en": "During sleep the body repairs tissues and consolidates memory. An adult needs on average 7-9 hours per night."}, "source": "llm-draft:7b+reviewed:claude"}
{"id": "health.hydration", "category": "health", "action": "answer", "arg": "", "reply": {"it": "L'idratazione è il mantenere nel corpo la giusta quantità di acqua, indispensabile per vivere e far funzionare gli organi.", "en": "Hydration is keeping the right amount of water in the body, essential for life and for the organs to work."}, "ask": {"it": ["cos'è l'idratazione", "perché è importante bere acqua", "a cosa serve l'acqua nel corpo", "cosa significa idratarsi"], "en": ["what is hydration", "why is drinking water important", "what does water do in the body"]}, "detail": {"it": "L'acqua è circa il 60% del corpo umano; regola la temperatura e trasporta i nutrienti. Conviene bere a sufficienza ogni giorno.", "en": "Water makes up about 60% of the human body; it regulates temperature and transports nutrients. It is best to drink enough every day."}, "source": "llm-draft:7b+reviewed:claude"}
{"id": "health.calories", "category": "health", "action": "answer", "arg": "", "reply": {"it": "La caloria è un'unità di misura dell'energia, usata soprattutto per indicare l'energia che il cibo fornisce al corpo.", "en": "The calorie is a unit of energy, used mainly to indicate the energy that food provides to the body."}, "ask": {"it": ["cosa sono le calorie", "che cosa sono le calorie", "cos'è una caloria", "a cosa servono le calorie"], "en": ["what are calories", "what is a calorie", "what are calories for"]}, "detail": {"it": "Sulle etichette si usano le chilocalorie (kcal). Il corpo le brucia per muoversi e funzionare; un adulto ne consuma circa 2000-2500 al giorno.", "en": "Food labels use kilocalories (kcal). The body burns them to move and function; an adult uses roughly 2000-2500 per day."}, "source": "llm-draft:7b+reviewed:claude"}
