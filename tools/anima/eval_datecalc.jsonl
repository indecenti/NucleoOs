// Calendar date arithmetic (anima_solve.c a_date_specific) — the WEEKDAY of a fixed date and the DAYS-UNTIL
// a date/holiday, real deterministic arithmetic that previously abstained ("I only count from today").
// Positives must route to the date skill; the impossible date is an honest in-skill decline (still intent=date);
// statements carrying a date/holiday must NOT fabricate a fact (abstain / honest decline).
{"q":"che giorno della settimana e il 25 dicembre 2026","lang":"it","expect":"date"}
{"q":"che giorno e il 1 gennaio 2027","lang":"it","expect":"date"}
{"q":"che giorno cade il 14 febbraio 2027","lang":"it","expect":"date"}
{"q":"quanti giorni mancano a natale","lang":"it","expect":"date"}
{"q":"quanti giorni mancano al 25 dicembre","lang":"it","expect":"date"}
{"q":"quanto manca a capodanno","lang":"it","expect":"date"}
{"q":"quanti giorni mancano a ferragosto","lang":"it","expect":"date"}
{"q":"che giorno e il 30 febbraio 2025","lang":"it","expect":"date"}
{"q":"che giorno e oggi","lang":"it","expect":"date"}
{"q":"che giorno e domani","lang":"it","expect":"date"}
{"q":"fra 3 giorni che giorno e","lang":"it","expect":"date"}
{"q":"what day of the week is december 25 2026","lang":"en","expect":"date"}
{"q":"what weekday is july 4 2026","lang":"en","expect":"date"}
{"q":"how many days until christmas","lang":"en","expect":"date"}
{"q":"how many days until new year","lang":"en","expect":"date"}
{"q":"how many days until halloween","lang":"en","expect":"date"}
// days-in-month (exact, leap-aware)
{"q":"quanti giorni ha febbraio","lang":"it","expect":"date"}
