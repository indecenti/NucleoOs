{"q":"how many days in april","lang":"en","expect":"date"}
{"q":"how many days does february 2024 have","lang":"en","expect":"date"}
// hours between two clock times (overnight wraps; numbers that aren't clock times fall through)
{"q":"quante ore da 9 a 17","lang":"it","expect":"date"}
{"q":"quante ore da 9:30 a 18:00","lang":"it","expect":"date"}
{"q":"quante ore da 22 a 6","lang":"it","expect":"date"}
{"q":"how many hours from 9am to 5pm","lang":"en","expect":"date"}
{"q":"quante ore per 100 km a 50 kmh","lang":"it","expect":"phys"}
{"q":"quante ore ho dormito","lang":"it","expect":"abstain"}
{"q":"quanto tempo ci vogliono, 8 o 10 minuti per cuocere la pasta","lang":"it","expect":"abstain"}
{"q":"how long does it take, 2 or 3 minutes to boil an egg","lang":"en","expect":"abstain"}
{"q":"da 8 a 10 minuti per cuocere","lang":"it","expect":"abstain"}
// zodiac sign of a birth date + past-direction days ("giorni fa")
{"q":"che segno zodiacale e chi nasce il 5 agosto","lang":"it","expect":"date"}
{"q":"che segno e chi nasce il 23 agosto","lang":"it","expect":"date"}
{"q":"what star sign is someone born on march 21","lang":"en","expect":"date"}
