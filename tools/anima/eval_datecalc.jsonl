{"q":"quanti giorni fa era il 25 dicembre","lang":"it","expect":"date"}
// age from an explicit birth year (fixes the old convert misfire)
{"q":"quanti anni ha chi e nato nel 1990","lang":"it","expect":"date"}
{"q":"quanti anni ha una persona nata nel 1985","lang":"it","expect":"date"}
{"q":"che eta ha chi e nato nel 2000","lang":"it","expect":"date"}
