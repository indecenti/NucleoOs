// Everyday tech concepts — the "sai cos'e X?" long tail (smartphone, android, internet...). Bilingual.
{"id": "tech.smartphone", "category": "science", "action": "answer", "reply": {"it": "Uno smartphone e un telefono cellulare intelligente: oltre a chiamare, esegue app, naviga in internet, ha fotocamera, schermo touch e sensori.", "en": "A smartphone is an intelligent mobile phone: beyond calls it runs apps, browses the internet, and has a camera, a touchscreen and sensors."}, "ask": {"it": ["cos'e uno smartphone", "sai cos'e uno smartphone", "che cos'e uno smartphone", "cosa significa smartphone", "telefono intelligente"], "en": ["what is a smartphone", "do you know what a smartphone is", "what does smartphone mean"]}, "source": "hand"}
{"id": "tech.iphone", "category": "science", "action": "answer", "reply": {"it": "L'iPhone e lo smartphone prodotto da Apple, usa il sistema operativo iOS. E' famoso per il design e l'integrazione tra hardware e software.", "en": "The iPhone is the smartphone made by Apple, running the iOS operating system. It is known for its design and tight hardware-software integration."}, "ask": {"it": ["cos'e un iphone", "sai cos'e un iphone", "che cos'e l'iphone", "iphone cosa e"], "en": ["what is an iphone", "do you know what an iphone is", "what is the iphone"]}, "source": "hand"}
{"id": "tech.android", "category": "science", "action": "answer", "reply": {"it": "Android e il sistema operativo per smartphone e tablet sviluppato da Google, basato su Linux. E' il piu diffuso al mondo ed e usato da molti produttori.", "en": "Android is the operating system for smartphones and tablets developed by Google, based on Linux. It is the most widespread in the world and used by many makers."}, "ask": {"it": ["cos'e android", "conosci android", "sai cos'e android", "che cos'e android", "android cosa e"], "en": ["what is android", "do you know android", "what is android os"]}, "source": "hand"}
{"id": "tech.computer", "category": "science", "action": "answer", "reply": {"it": "Un computer e una macchina che elabora dati eseguendo programmi: ha un processore (CPU), memoria, e dispositivi di ingresso e uscita.", "en": "A computer is a machine that processes data by running programs: it has a processor (CPU), memory, and input/output devices."}, "ask": {"it": ["cos'e un computer", "che cos'e un computer", "sai cos'e un computer", "cosa fa un computer"], "en": ["what is a computer", "what does a computer do"]}, "source": "hand"}
{"id": "tech.internet", "category": "science", "action": "answer", "reply": {"it": "Internet e la rete mondiale che collega miliardi di dispositivi, permettendo di scambiare dati, pagine web, messaggi ed email tramite protocolli comuni.", "en": "The internet is the worldwide network connecting billions of devices, letting them exchange data, web pages, messages and email through common protocols."}, "ask": {"it": ["cos'e internet", "che cos'e internet", "sai cos'e internet", "come funziona internet"], "en": ["what is the internet", "how does the internet work"]}, "source": "hand"}
{"id": "tech.app", "category": "science", "action": "answer", "reply": {"it": "Un'app (applicazione) e un programma che svolge un compito specifico, come la calcolatrice o il lettore musicale. Su NucleoOS dimmi 'apri <nome app>'.", "en": "An app (application) is a program that does a specific task, like a calculator or a music player. On NucleoOS just say 'open <app name>'."}, "ask": {"it": ["cos'e un'app", "cos'e una app", "che cos'e un'applicazione", "cosa significa app"], "en": ["what is an app", "what is an application", "what does app mean"]}, "source": "hand"}
{"id": "tech.ai", "category": "science", "action": "answer", "reply": {"it": "L'intelligenza artificiale (IA) e la capacita di una macchina di svolgere compiti che richiedono intelligenza, come capire il linguaggio o riconoscere immagini.", "en": "Artificial intelligence (AI) is a machine's ability to perform tasks that need intelligence, such as understanding language or recognizing images."}, "ask": {"it": ["cos'e l'intelligenza artificiale", "cos'e l'ia", "che cos'e l'intelligenza artificiale", "cos'e l'ai", "sai cos'e l'intelligenza artificiale", "Intelligenza artificiale", "cos'è Intelligenza artificiale", "che cos'è Intelligenza artificiale", "spiegami Intelligenza artificiale", "parlami di Intelligenza artificiale", "definizione di intelligenza artificiale", "spiegami l'intelligenza artificiale", "come funziona l'intelligenza artificiale", "ai", "cos'è ai", "cos'è la ai"], "en": ["what is artificial intelligence", "what is ai", "what does ai mean", "what is Intelligenza artificiale", "explain Intelligenza artificiale", "explain artificial intelligence", "how does artificial intelligence work"]}, "source": "hand", "detail": {"it": "L'intelligenza artificiale (in sigla italiana IA o inglese AI) è la capacità o il tentativo di un sistema artificiale (tipicamente un sistema informatico o di un sistema di automazione) di simulare una generica forma di intelligenza naturale. Il Parlamento UE ha definito l'intelligenza artificiale come «la capacità di un sistema di mostrare capacità umane quali il ragionamento, l'apprendimento, la pianificazione e la creatività».", "en": ""}}
{"id": "tech.robot", "category": "science", "action": "answer", "reply": {"it": "Un robot e una macchina programmabile capace di svolgere compiti in automatico, spesso percependo l'ambiente con sensori e agendo con motori.", "en": "A robot is a programmable machine that can carry out tasks automatically, often sensing its environment with sensors and acting with motors."}, "ask": {"it": ["cos'e un robot", "che cos'e un robot", "sai cos'e un robot", "cosa fa un robot"], "en": ["what is a robot", "what does a robot do"]}, "source": "hand"}
{"id": "tech.gps", "category": "science", "action": "answer", "reply": {"it": "Il GPS e un sistema di satelliti che permette a un dispositivo di calcolare la propria posizione sulla Terra (latitudine e longitudine).", "en": "GPS is a system of satellites that lets a device compute its position on Earth (latitude and longitude)."}, "ask": {"it": ["cos'e il gps", "che cos'e il gps", "sai cos'e il gps", "a cosa serve il gps"], "en": ["what is gps", "what is gps for"]}, "source": "hand"}
{"id": "tech.touchscreen", "category": "science", "action": "answer", "reply": {"it": "Un touchscreen e uno schermo che rileva il tocco delle dita, permettendo di comandare il dispositivo toccando direttamente quello che si vede.", "en": "A touchscreen is a display that detects finger touches, letting you control the device by touching what you see."}, "ask": {"it": ["cos'e un touchscreen", "che cos'e lo schermo touch", "sai cos'e un touchscreen", "schermo tattile"], "en": ["what is a touchscreen", "what is a touch screen"]}, "source": "hand"}
{"id": "tech.password", "category": "science", "action": "answer", "reply": {"it": "Una password e una parola o codice segreto che protegge l'accesso a un account o dispositivo, dimostrando che sei autorizzato.", "en": "A password is a secret word or code that protects access to an account or device, proving you are authorized."}, "ask": {"it": ["cos'e una password", "che cos'e una password", "a cosa serve una password", "cos'e una parola d'ordine"], "en": ["what is a password", "what is a password for"]}, "source": "hand"}
{"id": "tech.browser", "category": "science", "action": "answer", "reply": {"it": "Un browser e il programma che usi per visitare i siti web, come Chrome, Firefox o Safari. Interpreta le pagine HTML e le mostra a schermo.", "en": "A browser is the program you use to visit websites, like Chrome, Firefox or Safari. It interprets HTML pages and shows them on screen."}, "ask": {"it": ["cos'e un browser", "che cos'e un browser", "sai cos'e un browser", "a cosa serve il browser"], "en": ["what is a browser", "what is a web browser"]}, "source": "hand"}
{"id": "gen.seasons", "category": "science", "action": "answer", "reply": {"it": "Nell'emisfero nord le stagioni iniziano ai solstizi e agli equinozi: primavera ~20 marzo, estate ~21 giugno, autunno ~23 settembre, inverno ~21 dicembre.", "en": "In the northern hemisphere the seasons start at the solstices and equinoxes: spring ~Mar 20, summer ~Jun 21, autumn ~Sep 23, winter ~Dec 21."}, "ask": {"it": ["quando inizia l'estate", "quando comincia l'estate", "quando inizia la primavera", "quando iniziano le stagioni", "quando inizia l'inverno", "quando inizia l'autunno", "quando cambiano le stagioni", "quando comincia l'inverno"], "en": ["when does summer start", "when does spring start", "when do the seasons start", "when does winter begin"]}, "source": "hand"}
