{"id": "prog.comment", "category": "programming", "action": "answer", "arg": "", "reply": {"it": "Un commento è testo ignorato dal programma, per spiegare il codice.", "en": "A comment is text ignored by the program, used to explain the code."}, "ask": {"it": ["cos'è un commento", "a cosa servono i commenti"], "en": ["what is a comment", "what are comments for"]}, "lang_primary": "bi", "source": "curated"}
