{
  "id": "system-monitor",
  "name": "System Monitor",
  "version": "0.1.0",
  "version_code": 1,
  "min_os": "0.1.0",
  "platforms": [
    "esp32s3"
  ],
  "description": "Live device stats \u2014 memory, storage, uptime, app count, and a real-time event feed.",
  "category": "tools",
  "runtime": "web",
  "entry_service": "none",
  "web_route": "/apps/system-monitor/",
  "permissions": [
    "system.events"
  ],
  "mounts": {
    "app": "/apps/system-monitor/data"
  },
  "handles": {
    "role": "none",
    "extensions": []
  },
  "subscribes": [
    "system.boot",
    "fs.changed",
    "storage.status",
    "wifi.status"
  ],
  "publishes": [],
  "power": {
    "budget_class": "low",
    "wants_wakeup": [
      "keyboard"
    ]
  },
  "mesh": {
    "exposes": [],
    "consumes": []
  }
}