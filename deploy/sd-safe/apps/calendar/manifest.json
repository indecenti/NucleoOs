{
  "id": "calendar",
  "name": "Calendar",
  "version": "0.1.0",
  "version_code": 1,
  "min_os": "0.1.0",
  "platforms": ["esp32s3"],
  "description": "Month calendar with events saved on the device.",
  "category": "tools",
  "runtime": "web",
  "entry_service": "none",
  "web_route": "/apps/calendar/",
  "icon": "assets/icon.svg",
  "permissions": ["storage.shared"],
  "mounts": { "app": "/apps/calendar/data" },
  "handles": { "role": "none", "extensions": [] },
  "subscribes": [],
  "publishes": [],
  "power": { "budget_class": "low", "wants_wakeup": ["keyboard"] },
  "mesh": { "exposes": [], "consumes": [] }
}
