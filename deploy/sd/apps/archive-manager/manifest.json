{
  "id": "archive-manager",
  "name": "Archive Manager",
  "version": "1.0.0",
  "version_code": 1,
  "min_os": "0.1.0",
  "platforms": ["esp32s3"],
  "description": "Browse, extract and create ZIP archives stored on the device.",
  "category": "tools",
  "runtime": "web",
  "entry_service": "none",
  "web_route": "/apps/archive-manager/",
  "icon": "/apps/archive-manager/icon.svg",
  "permissions": ["storage.shared"],
  "mounts": { "app": "/apps/archive-manager/data" },
  "handles": { "role": "viewer", "extensions": ["zip"] },
  "subscribes": [],
  "publishes": [],
  "power": { "budget_class": "low", "wants_wakeup": ["keyboard"] },
  "mesh": { "exposes": [], "consumes": [] }
}
