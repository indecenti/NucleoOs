{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "nucleoos/file-associations.schema.json",
  "title": "NucleoOS File Associations",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema", "fallback", "default_open"],
  "properties": {
    "schema": { "type": "integer", "minimum": 1 },
    "fallback": { "type": "string", "pattern": "^[a-z0-9][a-z0-9-]*$" },
    "default_open": {
      "type": "object",
      "additionalProperties": { "type": "string", "pattern": "^[a-z0-9][a-z0-9-]*$" }
    }
  }
}
